<% layout("layouts/boilerplate") %>

<body class="bg-light">
  <div class="container mt-5 listing-details bg-white">
      <h2 class="fw-bold mb-3"><%= doc.title %></h2>
    <!-- Image Banner -->
    <div class="listing-image mb-4 listing-details bg-white">
      <img src="<%= doc.image.path %>" alt="Listing Image" class="img-fluid rounded shadow-sm">
    </div>

    <!-- Details Card -->
     <div class="listing-details bg-white p-4 rounded shadow-sm">
      <p class="text-muted mb-4"><b>Hosted By:</b><%= doc.owner.username %></p>
      <p class="text-muted mb-4"><%= doc.description %></p>

      <div class="mb-3">
        <p class="fs-4 fw-semibold text-success">₹<%= doc.price.toLocaleString("en-IN") %> / night</p>
        <p class="text-secondary"><%= doc.location %>, <%= doc.country %></p>
      </div>

      <!-- Action Buttons -->
       <% if(currUser && currUser._id.equals(doc.owner._id)){%>
         <div class="d-flex gap-3 mt-4">
        <form action="/Listings/<%= doc._id %>/Edit" method="get">
          <button type="submit" class="btn btn-outline-dark px-4">Edit</button>
        </form>
        <form action="/Listings/<%= doc._id %>?_method=delete" method="post">
          <button type="submit" class="btn btn-outline-dark px-4">Delete</button>
        </form>
      
    </div>
  
       <%}%>
     
   
    <%if(currUser && currUser.length!=0){%>
       <hr>
 <div class="review">
  <h2>Leave your Review!</h2>

  <form action="/listings/<%= doc._id %>/reviews"
        method="post"
        novalidate
        class="needs-validation">

    <div class="reviewform">

      <div>
        <label for="cm" class="form-label" style="padding-top:10px;">
          Comment:
        </label>

        <textarea
          id="cm"
          name="comment"
          class="form-control"
          required></textarea>

        <div class="valid-feedback">
          Looks Good!
        </div>

        <div class="invalid-feedback">
          Enter A Valid Comment!
        </div>
      </div>

      <fieldset class="starability-slot">
        <legend>Give rating:</legend>

        <input type="radio" id="no-rate" class="input-no-rate"
               name="rating" value="0" checked />

        <input type="radio" id="first-rate1" name="rating" value="1" />
        <label for="first-rate1">1 star</label>

        <input type="radio" id="first-rate2" name="rating" value="2" />
        <label for="first-rate2">2 stars</label>

        <input type="radio" id="first-rate3" name="rating" value="3" />
        <label for="first-rate3">3 stars</label>

        <input type="radio" id="first-rate4" name="rating" value="4" />
        <label for="first-rate4">4 stars</label>

        <input type="radio" id="first-rate5" name="rating" value="5" />
        <label for="first-rate5">5 stars</label>
      </fieldset>

      <div style="display:flex; justify-content:center; margin:15px 0;">
        <button class="btn btn-outline-dark px-4">
          Submit
        </button>
      </div>

    </div> <!-- reviewform -->

  </form>
 <!-- </div> -->
   <% }%>
 <script>
    let slider = document.querySelector("#rating");
    let value = document.querySelector("#value");
    slider.addEventListener("input", () => {
        value.textContent = slider.value;
    });
 </script>
    </form>
  <% if(doc.reviews.length!=0){ %>
     <hr>
    <h4>All Reviews</h4>
  <div class="AllReviews">
  <% for( let i =0 ; i<doc.reviews.length;i++){ %>
   <div class="card" style="width: 20rem;">
  <div class="card-header">
     Review by <b>@<%=doc.reviews[i].author.username%></b>
  </div>
  <div class="card-body">
    <figure>
        <p class="comment"><i>"<%=doc.reviews[i].comment%>"</i></p>
    <p class="starability-result card-text" data-rating="<%=doc.reviews[i].rating%>">
    Rated: 3
  </p>
    </figure>
  </div>
  <% if(currUser && currUser._id.equals(doc.reviews[i].author._id)){%>
 <form action="/listings/<%=doc._id%>/review/<%=doc.reviews[i]._id%>?_method=delete" method="post">
    <button class="btn btn-dark" style="margin-left: 10px; margin-bottom: 10px;">Delete!</button>
 </form>
  <%}%>
</div>
<% } %>
<% } %>
</div>
 </div>


<div class="listing-details bg-white">
<hr>
<h4>Location</h4>
<div id="map" class="listing-details bg-white"></div>
<script>
   let MapToken = "<%=process.env.MAP_TOKEN %>"
   console.log(MapToken);
    const map = new mapboxgl.Map({
        accessToken: MapToken,
        container: 'map',
        style: 'mapbox://styles/mapbox/standard', // Use the standard style for the map
 // display the map as a globe
        zoom: 9, // initial zoom level, 0 is the world view, higher values zoom in
        center: ["<%= longitude %>", "<%= latitude %>"] // center the map on this longitude and latitude
    });
    // Create An Marker On An Map
   const marker = new mapboxgl.Marker({
    color: 'black'
})
.setLngLat(["<%= longitude %>", "<%= latitude %>"]) // inject as numbers
.addTo(map);
    map.addControl(new mapboxgl.NavigationControl());
    map.scrollZoom.disable();
    map.on('style.load', () => {
        map.setFog({}); // Set the default atmosphere style
    });
</script>
  </div>
   </div>
</body>
